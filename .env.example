# Development environment defaults
SENTINEL_ENV=dev
SENTINEL_LOG_LEVEL=debug

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=sentinel
DB_PASSWORD=sentinel
DB_NAME=sentinelhub

# Redis
REDIS_ADDR=localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Server
HTTP_ADDR=:8080

# Agent
AGENT_SERVER_URL=http://localhost:8080
AGENT_HEARTBEAT_INTERVAL=60s

# Remote assist WebRTC / TURN (production)
# Comma-separated TURN URLs (UDP + TCP recommended)
REMOTE_TURN_URL=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
# Shared secret — must match deploy/coturn TURN_STATIC_AUTH_SECRET (enables ephemeral credentials)
REMOTE_TURN_SECRET=
REMOTE_TURN_CREDENTIAL_TTL=86400
# Dev fallback: static credentials instead of REMOTE_TURN_SECRET
# REMOTE_TURN_USERNAME=
# REMOTE_TURN_CREDENTIAL=
