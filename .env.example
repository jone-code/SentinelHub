# Development environment defaults
SENTINEL_ENV=dev
SENTINEL_LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sentinel
DB_PASSWORD=sentinel
DB_NAME=sentinelhub

# Redis
REDIS_ADDR=localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Gateway
HTTP_ADDR=:8080

# Agent
AGENT_SERVER_URL=http://localhost:8080
AGENT_HEARTBEAT_INTERVAL=60s
