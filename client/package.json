{
  "name": "sentinelhub-client",
  "version": "0.1.0",
  "private": true,
  "description": "SentinelHub PC desktop client with UI and background service",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:ui": "tsc && vite build",
    "build": "npm run build:ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.0"
  }
}
