# Copy to .env and fill in credentials before `docker compose up`

# PagerDuty Events API v2 routing key (critical alerts)
PAGERDUTY_ROUTING_KEY=

# DingTalk custom robot webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# Optional: DingTalk robot sign secret
DINGTALK_SECRET=

# Feishu (Lark) custom bot webhook URL (info-level alerts)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN

# Grafana OnCall integration token (optional, see docs/operations/grafana-oncall.md)
GRAFANA_ONCALL_TOKEN=
